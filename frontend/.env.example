# Supabase — get these from Supabase Dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Backend API
# Leave blank for local development — the app auto-detects the backend IP via Expo.
# Set this ONLY for production deployments, e.g: https://heritageai.up.railway.app
EXPO_PUBLIC_API_URL=
