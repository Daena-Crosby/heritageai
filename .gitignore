# ============================
# Environment & Secrets — NEVER commit these
# ============================
.env
.env.*
!.env.example          # Allow example files (no real keys)
**/.env
**/.env.*
!**/.env.example
*.local                # .env.local, config.local, etc.

# Certificates & keys
*.pem
*.key
*.p12
*.p8
*.p8.enc
*.pfx
*.jks
*.keystore             # Android release keystore
*.mobileprovision

# SSH keys (in case anyone puts them in the project)
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
id_dsa
id_ecdsa

# Generic secret files
*.secret
*.secrets
*.token
*.tokens
*.password
*.passwords
*.credentials
*.credential

# Service account / cloud provider keys
serviceAccountKey.json
service-account*.json
*-service-account.json
google-services.json        # Firebase Android config (contains API keys)
GoogleService-Info.plist    # Firebase iOS config (contains API keys)
gcloud-key.json
aws-credentials
.aws/credentials

# Package manager auth (may contain private registry tokens)
.npmrc
.yarnrc
.yarn/

# Supabase & auth exports
supabase-key*.json
auth-export*.json

# Secrets and credential directories
secrets/
credentials/
certs/
keys/
private/

# ============================
# Dependencies
# ============================
node_modules/
.pnp
.pnp.js
.yarn/

# ============================
# Build Output
# ============================
build/
dist/
out/
web-build/
*.tsbuildinfo

# ============================
# Testing & Coverage
# ============================
coverage/
.nyc_output/

# ============================
# Expo & React Native
# ============================
.expo/
.expo-shared/
*.orig.*
android/
ios/

# ============================
# Logs
# ============================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ============================
# OS Files
# ============================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ============================
# IDE & Editor
# ============================
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project
.history/

# ============================
# Temporary / Cache Files
# ============================
*.tmp
*.temp
.cache/
tmp/
temp/

# ============================
# FFMPEG temp files (video generation)
# ============================
*.mp4.tmp
/tmp/*.mp4
/tmp/*.png

# ============================
# Supabase local dev
# ============================
supabase/.temp/
supabase/config.toml

# ============================
# Expo / EAS Build
# ============================
# eas.json can contain environment variables for builds — keep out of source
# (only ignore if you put secrets in it; the base file is usually safe to commit)
# eas-credentials.json — never commit
eas-credentials.json
.eas/
# Expo private keys for OTA updates
private-key.pem

# ============================
# Legacy / root-level web app files
# (kept in repo but not built)
# ============================
# vite build output already covered by dist/ above
.claude/

# ============================
# Security Documentation — NEVER commit
# ============================
# Security audit reports contain sensitive implementation details
SECURITY_AUDIT.md
**/SECURITY_AUDIT.md
security-audit*.md
**/security-audit*.md
penetration-test*.md
vulnerability-report*.md

# ============================
# Editor Backup Files
# ============================
*-safeBackup-*.ts
*-safeBackup-*.js
*-safeBackup-*.json
*.backup
*.bak
