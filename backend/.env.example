# Supabase — get these from Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here   # Keep secret — never expose to frontend

# Hugging Face (used for Whisper transcription, image generation, theme classification) — get from https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=hf_your_token_here

# Groq (used for dialect translation and Cultural Guide chat)
GROQ_API_KEY=

# Server
PORT=3000
NODE_ENV=development

# CORS — comma-separated list of allowed origins
# Add your Expo dev URL if needed (usually not required — Expo app has no Origin header)
CORS_ORIGIN=http://localhost:8081

# Auth — URL to redirect to after password reset (update for production)
PASSWORD_RESET_REDIRECT_URL=http://localhost:8081/reset-password
